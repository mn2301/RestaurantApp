<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:syncfusion="clr-namespace:Syncfusion.Maui.DataGrid;assembly=Syncfusion.Maui.DataGrid"
             x:Class="RestaurantApp.SalesReport"
             Title="Reporte de ventas"
             BackgroundColor="#131313">

    <Grid RowDefinitions="Auto, Auto, Auto, Auto" Padding="16">
        <HorizontalStackLayout Grid.Row="0" HorizontalOptions="Center" Margin="0,10,0,0">
            <Label Text="Reportes" TextColor="#E5E2E1" FontSize="28" FontFamily="ZalandoSans" FontAttributes="Bold"/>
        </HorizontalStackLayout>
        <!-- Date filter -->
        <HorizontalStackLayout Grid.Row="1">
            <Label Text="MOSTRAR LA INFORMACIÓN DE:" VerticalOptions="Center" TextColor="#74A173" FontSize="12" FontFamily="ZalandoSans" Margin="0,0,10,0"/>
            <Border Padding="10, 1" BackgroundColor="#2A2A2A" Stroke="#1C1B1B">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>

                <Picker x:Name="pkTimePeriod" Title="Seleccionar" TitleColor="#E5E2E1" TextColor="Black" BackgroundColor="Transparent" FontFamily="ZalandoSans" SelectedIndexChanged="pkTimePeriod_SelectedIndexChanged">
                    <Picker.ItemsSource>
                        <x:Array Type="{x:Type x:String}">
                            <x:String>Día</x:String>
                            <x:String>Semana</x:String>
                            <x:String>Mes</x:String>
                        </x:Array>
                    </Picker.ItemsSource>
                </Picker>
            </Border>
        </HorizontalStackLayout>
        
        <!-- KPI -->
        <HorizontalStackLayout Grid.Row="2" Spacing="15" HorizontalOptions="Center" Margin="0,20,0,0">
            <!-- Amount of orders -->
            <Border Padding="15" BackgroundColor="#2A2A2A" HeightRequest="80" Stroke="#1C1B1B">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>

                <VerticalStackLayout>
                    <Label Text="ORDENES" VerticalOptions="Center" TextColor="#74A173" FontSize="12" FontFamily="ZalandoSans"/>
                    <Label x:Name="lblOrder" Text="0" VerticalOptions="Center" HorizontalOptions="Center" FontAttributes="Bold" TextColor="#E5E2E1" FontSize="28" FontFamily="ZalandoSans"/>
                </VerticalStackLayout>
            </Border>

            <!-- Sales -->
            <Border Padding="15" BackgroundColor="#2A2A2A" HeightRequest="80" Stroke="#1C1B1B">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>

                <VerticalStackLayout>
                    <Label Text="VENTAS" VerticalOptions="Center" HorizontalOptions="Center" TextColor="#74A173" FontSize="12" FontFamily="ZalandoSans"/>
                    <Label x:Name="lblSales" Text="0" VerticalOptions="Center" HorizontalOptions="Center" FontAttributes="Bold" TextColor="#E5E2E1" FontSize="28" FontFamily="ZalandoSans"/>
                </VerticalStackLayout>
            </Border>
        </HorizontalStackLayout>

        <!-- Orders grid (Syncfusion) -->
        <Border Grid.Row="3" BackgroundColor="#2A2A2A" HeightRequest="550" Stroke="#1C1B1B" Margin="0,20,0,0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="20" />
            </Border.StrokeShape>
            
            <syncfusion:SfDataGrid x:Name="orderGrid" HeightRequest="550" AutoGenerateColumnsMode="None" ColumnWidthMode="FitByCell"  HeaderRowHeight="50" RowHeight="80" SelectionMode="None" BackgroundColor="Transparent" HorizontalScrollBarVisibility="Always" VerticalScrollBarVisibility="Always">
                <syncfusion:SfDataGrid.DefaultStyle>
                    <syncfusion:DataGridStyle HeaderRowBackground="#1C1B1B" HeaderRowTextColor="#74A173" RowTextColor="#E5E2E1" HeaderRowFontSize="12" HeaderRowFontAttributes="Bold"/>
                </syncfusion:SfDataGrid.DefaultStyle>

                <syncfusion:SfDataGrid.Columns>
                    <syncfusion:DataGridTemplateColumn HeaderText="FECHA" Width="100" HeaderTextAlignment="Center">
                        <syncfusion:DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Label Text="{Binding order.date}" TextColor="#E5E2E1" HorizontalOptions="Center" LineBreakMode="WordWrap" FontFamily="ZalandoSans" VerticalOptions="Center" FontSize="12"/>
                            </DataTemplate>
                        </syncfusion:DataGridTemplateColumn.CellTemplate>
                    </syncfusion:DataGridTemplateColumn>

                    <syncfusion:DataGridTemplateColumn HeaderText="CLIENTE" Width="100" HeaderTextAlignment="Center">
                        <syncfusion:DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Label Text="{Binding users.clientName}" LineBreakMode="WordWrap" HorizontalOptions="Center" TextColor="#E5E2E1" FontFamily="ZalandoSans" VerticalOptions="Center" FontSize="12"/>
                            </DataTemplate>
                        </syncfusion:DataGridTemplateColumn.CellTemplate>
                    </syncfusion:DataGridTemplateColumn>

                    <syncfusion:DataGridTemplateColumn HeaderText="ESTADO" Width="100" HeaderTextAlignment="Center">
                        <syncfusion:DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Label Text="{Binding order.status}" LineBreakMode="WordWrap" HorizontalOptions="Center" TextColor="#E5E2E1" FontFamily="ZalandoSans" VerticalOptions="Center" FontSize="12"/>
                            </DataTemplate>
                        </syncfusion:DataGridTemplateColumn.CellTemplate>
                    </syncfusion:DataGridTemplateColumn>

                    <syncfusion:DataGridTemplateColumn HeaderText="$" Width="100" HeaderTextAlignment="Center">
                        <syncfusion:DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Label Text="{Binding order.totalprice, StringFormat='{0:C2}'}" HorizontalOptions="Center" TextColor="#E5E2E1" FontFamily="ZalandoSans" VerticalOptions="Center" FontSize="12"/>
                            </DataTemplate>
                        </syncfusion:DataGridTemplateColumn.CellTemplate>
                    </syncfusion:DataGridTemplateColumn>

                    <syncfusion:DataGridTemplateColumn Width="50">
                        <syncfusion:DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Image x:Name="imgLink" Source="link.png" BackgroundColor="Transparent" WidthRequest="20" HeightRequest="20">
                                    <Image.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="imgLink_Clicked"></TapGestureRecognizer>
                                    </Image.GestureRecognizers>
                                </Image>
                            </DataTemplate>
                        </syncfusion:DataGridTemplateColumn.CellTemplate>
                    </syncfusion:DataGridTemplateColumn>
                </syncfusion:SfDataGrid.Columns>
            </syncfusion:SfDataGrid>
        </Border>
    </Grid>
</ContentPage>