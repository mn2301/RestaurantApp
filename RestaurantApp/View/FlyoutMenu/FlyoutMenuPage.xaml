<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:RestaurantApp"
             x:Class="RestaurantApp.FlyoutMenuPage"
             Padding="0,40,0,0"
             BackgroundColor="#1D1D1D"
             Title="Makos Sushi &amp; Bar">

    <Grid RowDefinitions="Auto, *, Auto" Padding="0,40,0,20">

        <!-- Icon and name -->
        <StackLayout Grid.Row="0" HorizontalOptions="Center" Margin="0,0,0,20">
            <Image Source="sushiicon.png" HeightRequest="80" WidthRequest="80" HorizontalOptions="Center"/>
            <Label Text="MAKOS SUSHI &amp; BAR" TextColor="#F4F4F2" FontSize="22" FontAttributes="Bold" HorizontalOptions="Center" Margin="0,10"/>
            <BoxView HeightRequest="1" Color="#444" Margin="20,0"/>
        </StackLayout>

        <!-- Menu tabs, created dynamically -->
        <CollectionView x:Name="collectionView" Grid.Row="1" x:FieldModifier="public" SelectionMode="Single">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="local:FlyoutPageItem">
                    <Grid Padding="15,12">
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroupList>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="Selected">
                                        <!-- Change a tabs bg color when it's selected -->
                                        <VisualState.Setters>
                                            <Setter Property="BackgroundColor" Value="#161616" />
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateGroupList>
                        </VisualStateManager.VisualStateGroups>

                        <!-- Separate icon and text by column -->
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="30"/>
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Image Source="{Binding IconSource}" />
                        <Label Grid.Column="1" Margin="20,0" Text="{Binding Title}" TextColor="#F4F4F2" FontSize="18" VerticalOptions="Center" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Logout section -->
        <HorizontalStackLayout Grid.Row="2" Margin="15,0,0,0">
            <HorizontalStackLayout.GestureRecognizers>
                <TapGestureRecognizer Tapped="btnLogout_Clicked"/>
            </HorizontalStackLayout.GestureRecognizers>

            <Image Source="logout.png" HeightRequest="35" WidthRequest="35" HorizontalOptions="Start"/>
            <Label Text="Cerrar sesión" VerticalOptions="Center" FontSize="18" TextColor="#F4F4F2" HorizontalOptions="Start" Margin="20,0"/>
        </HorizontalStackLayout>
    </Grid>

</ContentPage>