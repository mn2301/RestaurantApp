<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:RestaurantApp"
             x:Class="RestaurantApp.FullMenu"
             Title="Menu"
             BackgroundColor="#131313">

    <ScrollView>
        <Grid RowDefinitions="Auto, Auto, *, Auto">
            <!-- Nombre y carrito de compras -->
            <HorizontalStackLayout Grid.Row="0" Padding="20, 10" Spacing="60">
                <Label Text="Makos Sushi &amp; Bar" FontAttributes="Bold" FontFamily="ZalandoSans" FontSize="20" TextColor="#E5E2E1" CharacterSpacing="4" VerticalOptions="Center"/>
                <Grid Grid.Row="0" VerticalOptions="Center" HorizontalOptions="End">
                    <Image x:Name="imgCart" Source="cart.png" HeightRequest="26" WidthRequest="26">
                        <Image.GestureRecognizers>
                            <TapGestureRecognizer Tapped="TapGestureRecognizer_Tapped"/>
                        </Image.GestureRecognizers>
                    </Image>

                    <Border x:Name="cartBadge" Background="#74A173" Stroke="#74A173" HeightRequest="15" WidthRequest="15" HorizontalOptions="End" VerticalOptions="Start" TranslationX="5" TranslationY="-5" IsVisible="False">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="50" />
                        </Border.StrokeShape>
                        <Label x:Name="lblCartCount" Text="0" TextColor="White" FontSize="8" FontFamily="ZalandoSans" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                </Grid>
            </HorizontalStackLayout>

            <!-- Menu dinámico -->
            <CollectionView x:Name="cvSushiMenu" Grid.Row="2" Margin="20, 0" SelectionMode="Single" SelectionChanged="cvSushiMenu_SelectionChanged">
                <!-- Filtros de menu -->
                <CollectionView.Header>
                    <HorizontalStackLayout Spacing="10" Margin="0, 10, 0, 20">
                        <Button x:Name="btnAllMenu"  Text="Todo" BackgroundColor="#74A173" TextColor="#131313" FontFamily="ZalandoSans" CornerRadius="28" Clicked="btnAllMenu_Clicked"/>
                        <Button x:Name="btnSushiMenu" Text="Sushi" BackgroundColor="#2A2A2A" TextColor="#E5E2E1" FontFamily="ZalandoSans" CornerRadius="28" Clicked="btnSushiMenu_Clicked"/>
                        <Button x:Name="btnDrinkMenu" Text="Bebidas" BackgroundColor="#2A2A2A" TextColor="#E5E2E1" FontFamily="ZalandoSans" CornerRadius="28" Clicked="btnDrinkMenu_Clicked"/>
                    </HorizontalStackLayout>
                </CollectionView.Header>

                <!-- Templete para agregar cada artículo del menú -->
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border BackgroundColor="#1C1B1B" Stroke="#1C1B1B" Padding="10" Margin="0,0,0,10">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="28" />
                            </Border.StrokeShape>
                            
                            <Grid RowDefinitions="Auto, Auto" ColumnDefinitions="*, Auto">
                                <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" HorizontalOptions="Fill" HeightRequest="200" Stroke="#1C1B1B" BackgroundColor="#1C1B1B">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="18" />
                                    </Border.StrokeShape>
                                    <Image Source="{Binding ImageUrl}" Aspect="AspectFill"/>
                                </Border>
                                <VerticalStackLayout Grid.Row="1" Grid.Column="0" Margin="0, 10, 0, 0">
                                    <Label Text="{Binding Name}" FontFamily="ZalandoSans" TextColor="#E5E2E1" FontSize="18" FontAttributes="Bold"/>
                                    <Label Text="{Binding Description}" TextColor="#E5E2E1" Opacity="0.6" FontSize="14" Margin="0,0,30,0"/>
                                    <HorizontalStackLayout>
                                        <Label Text="{Binding Price, StringFormat='${0:F2}'}" FontFamily="ZalandoSans" TextColor="#74A173" FontSize="18" FontAttributes="Bold" VerticalOptions="Start" Margin="0, 5, 0, 0"/>
                                        <Label Text="•" FontFamily="ZalandoSans" TextColor="#E5E2E1" FontSize="18" FontAttributes="Bold" VerticalOptions="Start" Margin="10, 5, 0, 0" IsVisible="False">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label" Binding="{Binding Availability}" Value="No Disponible">
                                                    <Setter Property="IsVisible" Value="True" />
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                        <Label Text="{Binding Availability}" x:Name="lblAvailable" FontFamily="ZalandoSans" TextColor="#B04B4E" FontSize="18" FontAttributes="Bold" VerticalOptions="Start" Margin="10, 5, 0, 0" IsVisible="False">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label" Binding="{Binding Availability}" Value="No Disponible">
                                                    <Setter Property="IsVisible" Value="True" />
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                                <Button Grid.Row="1" Grid.Column="1" x:Name="btnAddToCart" Text="+" BackgroundColor="#2A2A2A" TextColor="#E5E2E1" FontSize="26" WidthRequest="44" HeightRequest="44" CornerRadius="18" Padding="0" Clicked="btnAddToCart_Clicked"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>
    </ScrollView>
</ContentPage>