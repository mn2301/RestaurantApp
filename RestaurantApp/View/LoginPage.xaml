<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RestaurantApp.LoginPage"
             Title="LoginPage"
             BackgroundColor="#131313">

    <Grid RowDefinitions="*, Auto, Auto" Padding="0,40,0,20">

        <Grid Grid.Row="0" HorizontalOptions="Fill">

            <Image Source="sushi.png" Aspect="AspectFill" HorizontalOptions="End" TranslationX="90" MaximumHeightRequest="500" Margin="0,13,0,0"/>

            <!-- Restaurant name -->
            <VerticalStackLayout Spacing="2" HorizontalOptions="Start" Margin="80,-5,0,0">
                <Label Text="M" Style="{StaticResource LetterStyle}"/>
                <Label Text="A" Style="{StaticResource LetterStyle}"/>
                <Label Text="K" Style="{StaticResource LetterStyle}"/>
                <Label Text="O" Style="{StaticResource LetterStyle}"/>
                <Label Text="S" Style="{StaticResource LetterStyle}"/>

                <BoxView HeightRequest="20" Color="Transparent"/>

                <Label Text="S" Style="{StaticResource LetterStyle}"/>
                <Label Text="U" Style="{StaticResource LetterStyle}"/>
                <Label Text="S" Style="{StaticResource LetterStyle}"/>
                <Label Text="H" Style="{StaticResource LetterStyle}"/>
                <Label Text="I" Style="{StaticResource LetterStyle}"/>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="2" HorizontalOptions="Start" Margin="140,-5,0,0">
                <Label Text="&amp;" Style="{StaticResource LetterStyle}" TextColor="#74A173"/>
                <Label Text="B" Style="{StaticResource LetterStyle}"/>
                <Label Text="A" Style="{StaticResource LetterStyle}"/>
                <Label Text="R" Style="{StaticResource LetterStyle}"/>
            </VerticalStackLayout>
        </Grid>

        <!-- Slogan ? -->
        <VerticalStackLayout Grid.Row="1" HorizontalOptions="Center" Margin="0,20">
            <Label Text="寿司" FontSize="100" FontFamily="YujiBoku" TextColor="#F4F4F2" HorizontalOptions="Center"/>
            <Label Text="DESCUBRE TU SUSHI FAVORITO" FontSize="12" CharacterSpacing="4" FontFamily="ZalandoSans" TextColor="#888888" HorizontalOptions="Center" Margin="0,-10,0,0"/>
        </VerticalStackLayout>

        <!-- Login button -->
        <Button Grid.Row="2" x:Name="btnLogin" Text="INICIAR SESIÓN" ImageSource="google.png" ContentLayout="Left, 15" BackgroundColor="#74A173" TextColor="White" FontAttributes="Bold" CharacterSpacing="2" CornerRadius="28" HeightRequest="55" WidthRequest="300" FontFamily="ZalandoSans" Margin="0,20,0,40" HorizontalOptions="Center" Clicked="btnLogin_Clicked"/>

    </Grid>

    <!-- Style to define the characteristics of the letters instead of placing it on each label -->
    <ContentPage.Resources>
        <Style x:Key="LetterStyle" TargetType="Label">
            <Setter Property="FontSize" Value="34"/>
            <Setter Property="FontFamily" Value="RocknRollOne"/>
            <Setter Property="TextColor" Value="#F4F4F2"/>
            <Setter Property="HorizontalOptions" Value="Center"/>
        </Style>
    </ContentPage.Resources>
</ContentPage>