<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RestaurantApp.MenuDetails"
             Title="Detalles"
             BackgroundColor="#131313"
             NavigationPage.HasNavigationBar="True"
             NavigationPage.IconColor="#74A173">

    <Grid RowDefinitions="*, Auto">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="0, 0, 0, 20">
                <!-- Imagen de artículo de menú -->
                <Image Source="{Binding ImageUrl}" HeightRequest="400" Aspect="AspectFill"/>

                <VerticalStackLayout Padding="20" Spacing="15">
                    <!-- Mostrar características y editar -->
                    <!-- Cantidad de piezas, alcohólico -->
                    <Grid ColumnDefinitions="Auto, *">
                        <HorizontalStackLayout Grid.Column="0" BindableLayout.ItemsSource="{Binding Characteristics}" Spacing="10" Margin="0, 5">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="10, 5" BackgroundColor="#2A2A2A">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="9" />
                                        </Border.StrokeShape>

                                        <Label Text="{Binding .}" TextColor="#74A173" FontSize="10" FontAttributes="Bold" FontFamily="ZalandoSans" CharacterSpacing="2"/>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </HorizontalStackLayout>
                        <Image x:Name="imgEdit" Grid.Column="1" HorizontalOptions="End" Source="edit.png" WidthRequest="30" HeightRequest="30">
                            <Image.GestureRecognizers>
                                <TapGestureRecognizer Tapped="imgEdit_Tapped"></TapGestureRecognizer>
                            </Image.GestureRecognizers>
                        </Image>
                    </Grid>

                    <!-- Nombre -->
                    <Label Text="{Binding Name}" TextColor="#E5E2E1" FontSize="32" FontAttributes="Bold" FontFamily="ZalandoSans"/>

                    <!-- Precio -->
                    <HorizontalStackLayout>
                        <Label Text="{Binding Price, StringFormat='${0:F2}'}" TextColor="#74A173" FontSize="24" FontAttributes="Bold" FontFamily="ZalandoSans"/>
                        <Label Text="•" FontFamily="ZalandoSans" TextColor="#E5E2E1" FontSize="24" FontAttributes="Bold" VerticalOptions="Start" Margin="10, 0, 0, 0" IsVisible="False">
                            <Label.Triggers>
                                <DataTrigger TargetType="Label" Binding="{Binding Availability}" Value="No Disponible">
                                    <Setter Property="IsVisible" Value="True" />
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                        <Label Text="{Binding Availability}" x:Name="lblAvailable" FontFamily="ZalandoSans" TextColor="#B04B4E" FontSize="24" FontAttributes="Bold" Margin="10, 0, 0, 0" IsVisible="False">
                            <Label.Triggers>
                                <DataTrigger TargetType="Label" Binding="{Binding Availability}" Value="No Disponible">
                                    <Setter Property="IsVisible" Value="True" />
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                    </HorizontalStackLayout>
                    
                    <!-- Descripción -->
                    <Label Text="DESCRIPCIÓN" TextColor="#E5E2E1" Opacity="0.6" FontSize="12" FontFamily="ZalandoSans" CharacterSpacing="2" Margin="0, 10, 0, 0"/>
                    <Label Text="{Binding Description}" TextColor="#E5E2E1" Opacity="0.8" FontSize="16" LineHeight="1.4"/>

                    <!-- Comentarios -->
                    <Label Text="INSTRUCCIONES ADICIONALES  " TextColor="#E5E2E1" Opacity="0.6" FontSize="12" CharacterSpacing="2" FontFamily="ZalandoSans" Margin="0, 10, 0, 0"/>
                    <Border Padding="15" BackgroundColor="#1C1B1B" Stroke="#424940">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20" />
                        </Border.StrokeShape>
                        <Editor x:Name="enComment" Placeholder="Alergias, sin un ingrediente, extras..." PlaceholderColor="#666" TextColor="#E5E2E1" FontFamily="ZalandoSans" AutoSize="TextChanges" BackgroundColor="Transparent"/>
                    </Border>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Footer fijado a la pantalla -->
        <Border Grid.Row="1" BackgroundColor="#131313" Padding="20" Stroke="#424940">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="28" />
            </Border.StrokeShape>
            <Grid ColumnDefinitions="Auto, *">
                <HorizontalStackLayout Spacing="15" VerticalOptions="Center">
                    <Button Text="-" x:Name="btnLess" BackgroundColor="#2A2A2A" TextColor="#E5E2E1" CornerRadius="18" WidthRequest="40" Clicked="btnLess_Clicked"/>
                    <Label Text="1" x:Name="lblAmount" TextColor="#E5E2E1" VerticalOptions="Center" FontSize="18"/>
                    <Button Text="+" x:Name="btnMore" BackgroundColor="#2A2A2A" TextColor="#E5E2E1" CornerRadius="18" WidthRequest="40" Clicked="btnMore_Clicked"/>
                </HorizontalStackLayout>
                <Button x:Name="btnAddToCart" Grid.Column="1" Margin="20, 0, 0, 0" Text="AGREGAR AL CARRITO" BackgroundColor="#74A173" TextColor="#131313" CornerRadius="28" FontAttributes="Bold" Clicked="btnAddToCart_Clicked"/>
            </Grid>
        </Border>
    </Grid>
</ContentPage>